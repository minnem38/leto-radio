# ── Required ──────────────────────────────────────────────────────────────────

# Your Discord bot token (https://discord.com/developers/applications)
DISCORD_TOKEN=your-bot-token-here

# Right-click channel → Copy Channel ID (needs Developer Mode on)
DISCORD_CHANNEL_ID=123456789012345678

# Public URL where your file server is reachable — what Minecraft streams from.
# With Nginx Proxy Manager + domain:   https://radio.yourdomain.com
# Without reverse proxy (direct):      http://your-pi-ip:8765
PUBLIC_URL=https://radio.yourdomain.com

# ── Optional ──────────────────────────────────────────────────────────────────

# Seconds before audio files are deleted (default: 3600 = 1 hour)
FILE_TTL_SECONDS=3600

# Local port for the file server (default: 8765)
FILESERVER_PORT=8765
