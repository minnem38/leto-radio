# Leto Radio - Environment Config
# Copy this to .env and fill in your values

# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# The exact name of your Discord channel (no #)
RADIO_CHANNEL_NAME=leto-radio

# Where downloaded music gets stored
MUSIC_DIR=/home/pi/leto-radio/music

# Max songs allowed in queue at once
MAX_QUEUE_SIZE=20
