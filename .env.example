# ── Required ──────────────────────────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-bot-token-here

# The ID of the Discord channel to watch
# (Right-click channel → Copy Channel ID, needs Developer Mode enabled)
DISCORD_CHANNEL_ID=123456789012345678

# Public URL where your file server is reachable from the internet.
# This is the URL Minecraft will use to stream audio.
# Examples:
#   https://radio.yourdomain.com   (with Nginx Proxy Manager + domain)
#   http://your-server-ip:8765     (direct, no reverse proxy)
PUBLIC_URL=https://radio.yourdomain.com

# ── Optional ──────────────────────────────────────────────────────────────────

# How long (in seconds) before audio files are auto-deleted. Default: 3600 (1 hour)
FILE_TTL_SECONDS=3600

# Port the file server listens on locally. Default: 8765
# (Only matters if not using a reverse proxy)
FILESERVER_PORT=8765
